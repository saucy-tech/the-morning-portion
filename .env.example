# Public site URL used for metadata, RSS, sitemap, and canonical links.
# Leave unset locally to default to http://localhost:3000.
NEXT_PUBLIC_DAILY_WORD_URL=

# Kit/ConvertKit subscription form.
# These are server-side only.
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Optional Vercel analytics toggle.
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
