# Copy this file to .env.local for local development.
# Keep real values out of git. Set the same runtime values in Vercel for production.

# Canonical site URL used for metadata, RSS, sitemap, Open Graph, and canonical links.
# Local dev can leave this blank to fall back to http://localhost:3000.
# Production should use: https://morningportion.com
NEXT_PUBLIC_MORNING_PORTION_URL=

# Optional footer link override. Leave blank to use the app default: https://saucy.tech
NEXT_PUBLIC_PERSONAL_SITE_URL=

# Kit/ConvertKit subscription form used by src/app/api/subscribe.
# Use the Kit v3 API key and the Morning Portion subscribe form ID.
# Do not use the GitHub Actions KIT_API_KEY here; that V4 key is only for draft broadcasts.
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# GitHub Actions-only values are configured in GitHub repository settings, not .env.local:
# - KIT_API_KEY
# - NEXT_PUBLIC_APP_URL
# - KIT_EMAIL_ADDRESS
# - KIT_MORNING_PORTION_TAG_ID
# - KIT_MORNING_PORTION_TEST_TAG_ID
