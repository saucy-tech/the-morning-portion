# Public site URL used for metadata, RSS, sitemap, and canonical links.
# In Vercel, set this to the stable production URL after connecting the repo.
NEXT_PUBLIC_MORNING_PORTION_URL=

# Optional footer link override. Defaults to https://saucy.tech.
NEXT_PUBLIC_PERSONAL_SITE_URL=

# Kit/ConvertKit subscription form.
# These are server-side only.
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=
